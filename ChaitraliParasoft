//LoginPage
using OpenQA.Selenium;
using Utilities;

namespace Pages
{
    public class LoginPage
    {
        private IWebDriver driver;
        private WaitHelper wait;

        public LoginPage(IWebDriver driver)
        {
            this.driver = driver;
            wait = new WaitHelper(driver);
        }

        private By username = By.Name("username");
        private By password = By.Name("password");
        private By loginBtn = By.CssSelector("input[value='Log In']");
        private By errorMsg = By.ClassName("error");
        private By logoutLink = By.LinkText("Log Out");

        public void Navigate()
        {
            driver.Navigate().GoToUrl("https://parabank.parasoft.com/");
        }

        public void Login(string user, string pass)
        {
            wait.WaitForElement(username).SendKeys(user);
            driver.FindElement(password).SendKeys(pass);
            driver.FindElement(loginBtn).Click();
        }

        public bool IsLoginSuccessful()
        {
            return wait.WaitForElement(logoutLink).Displayed;
        }

        public bool IsErrorDisplayed()
        {
            return wait.WaitForElement(errorMsg).Displayed;
        }
    }
}
//LoginTests.cs
   using OpenQA.Selenium;
using OpenQA.Selenium.Support.UI;
using System;

namespace Pages
{
    public class LoginPage
    {
        private readonly IWebDriver driver;
        private readonly WebDriverWait wait;

        // Constructor
        public LoginPage(IWebDriver driver)
        {
            this.driver = driver;
            wait = new WebDriverWait(driver, TimeSpan.FromSeconds(10));
        }

        // Page Elements
        private IWebElement Username => wait.Until(d => d.FindElement(By.Name("username")));
        private IWebElement Password => wait.Until(d => d.FindElement(By.Name("password")));
        private IWebElement LoginButton => wait.Until(d => d.FindElement(By.XPath("//input[@value='Log In']")));
        private IWebElement ErrorMessage => driver.FindElement(By.CssSelector(".error"));

        // Navigate to login page
        public void Navigate()
        {
            driver.Navigate().GoToUrl("https://parabank.parasoft.com/login.htm");
        }

        // Login method
        public void Login(string username, string password)
        {
            EnterUsername(username);
            EnterPassword(password);
            ClickLogin();
        }

        private void EnterUsername(string username)
        {
            Username.Clear();
            Username.SendKeys(username);
        }

        private void EnterPassword(string password)
        {
            Password.Clear();
            Password.SendKeys(password);
        }

        private void ClickLogin()
        {
            LoginButton.Click();
        }

        // Check if login is successful
        public bool IsLoginSuccessful()
        {
            try
            {
                // Wait for dashboard URL to appear
                wait.Until(d => d.Url.Contains("overview"));
                return true;
            }
            catch
            {
                return false;
            }
        }

        // Check if error message is displayed
        public bool IsErrorDisplayed()
        {
            try
            {
                return ErrorMessage.Displayed;
            }
            catch (NoSuchElementException)
            {
                return false;
            }
        }

        // Get exact error message text
        public string GetErrorMessage()
        {
            return IsErrorDisplayed() ? ErrorMessage.Text : string.Empty;
        }
    }
}
//Screenshot Utility
using OpenQA.Selenium;
using System;
using System.IO;

namespace Utilities
{
    public class ScreenshotHelper
    {
        public static void Capture(IWebDriver driver, string testName)
        {
            ITakesScreenshot ts = (ITakesScreenshot)driver;
            var screenshot = ts.GetScreenshot();

            string path = Path.Combine(Directory.GetCurrentDirectory(),
                "Screenshots", testName + "_" + DateTime.Now.Ticks + ".png");

            Directory.CreateDirectory("Screenshots");
            screenshot.SaveAsFile(path);
        }
    }
}
//Use Screenshot on failure
[TearDown]
public void TearDown()
{
    if (TestContext.CurrentContext.Result.Outcome.Status == NUnit.Framework.Interfaces.TestStatus.Failed)
    {
        ScreenshotHelper.Capture(driver, TestContext.CurrentContext.Test.Name);
    }

    driver.Quit();
}
